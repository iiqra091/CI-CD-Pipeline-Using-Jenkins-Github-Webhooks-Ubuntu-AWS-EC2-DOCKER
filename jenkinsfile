pipeline {
    agent any

    environment {
        CONTAINER_NAME = 'nestjs-app'
        IMAGE_NAME = 'nesths-image'
        EMAIL = 'iqranoor1822@gmail.com'
        PORT = '3000'
    }

    stages {

        stage('Clone Repo') {
            steps {
                git branch: 'main', url: 'https://github.com/iiqra091/CI-CD-Pipeline-Using-Jenkins-Github-Webhooks-Ubuntu-AWS-EC2-DOCKER.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t ${IMAGE_NAME} .'
            }
        }

        stage('Stop & Remove Previous Container') {
            steps {
                sh '''
                    docker stop ${CONTAINER_NAME} || true
                    docker rm ${CONTAINER_NAME} || true
                '''
            }
        }

        stage('Run Docker Container') {
            steps {
                sh '''
                    docker run -d -p ${PORT}:${PORT} --name ${CONTAINER_NAME} ${IMAGE_NAME}
                '''
            }
        }

        stage('Send Email Notification') {
            steps {
                emailext(
                    subject: "NestJS App Deployed Successfully on EC2!",
                    body: """The Jenkins build for the NestJS application has been completed successfully.
App URL: http://13.60.27.218:${PORT}/""",
                    to: "${EMAIL}"
                )
            }
        }
    }
}